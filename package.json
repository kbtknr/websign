{
  "name": "web-signature",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "types": "./lib/types.ts",
  "exports": {
    ".": {
      "types": "./lib/types.ts",
      "browser": "./lib/browser/index.ts",
      "node": "./lib/node/index.ts",
      "default": "./lib/node/index.ts"
    },
    "./browser": "./lib/browser/index.ts",
    "./node": "./lib/node/index.ts",
    "./types": "./lib/types.ts"
  },
  "description": "Web API request signature utilities for browser and Node.js.",
  "scripts": {
    "lint": "npm run lint:eslint && npm run lint:prettier && npm run lint:tsc",
    "lint:eslint": "eslint \"lib/**/*.ts\"",
    "lint:tsc": "tsc --noEmit",
    "lint:prettier": "prettier --check .",
    "test": "npm run test:node && npm run test:browser",
    "test:node": "vitest run",
    "test:browser": "playwright test",
    "test:watch": "vitest",
    "fix": "npm run fix:prettier && npm run fix:eslint",
    "fix:prettier": "prettier --write .",
    "fix:eslint": "eslint \"lib/**/*.ts\" --fix"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vite": "^7.1.11",
    "vitest": "^3.2.4"
  },
  "files": [
    "lib"
  ],
  "license": "UNLICENSED"
}
